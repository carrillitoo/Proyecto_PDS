<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="600.0" prefWidth="800.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.LoginController">
   <children>
      <Circle fill="#cfe5ff" opacity="0.2" radius="200.0" StackPane.alignment="TOP_RIGHT">
         <translateX>100.0</translateX>
         <translateY>-100.0</translateY>
      </Circle>

      <VBox alignment="CENTER" maxWidth="440.0" spacing="30.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text styleClass="brand-title" text="Trello PDS" />
                  <Rectangle height="6.0" styleClass="brand-underline" width="48.0" />
               </children>
            </VBox>

            <VBox spacing="25.0" styleClass="login-card">
               <padding>
                  <Insets bottom="40.0" left="35.0" right="35.0" top="35.0" />
               </padding>
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Bienvenido a Trello PDS" />
                        <Label style="-fx-text-fill: #404751;" text="Introduce tu email para continuar" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0">
                     <children>
                        <Label styleClass="input-label" text="EMAIL" />
                        <TextField fx:id="emailField" prefHeight="45.0" promptText="nombre@empresa.com" />
                     </children>
                  </VBox>

                  <Button fx:id="loginButton" maxWidth="500.0" onAction="#handleLogin" prefHeight="48.0" styleClass="primary-button" text="Solicitar Código" />

                  <HBox spacing="10.0" styleClass="info-box">
                     <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                        <Label styleClass="info-text" text="Recibirás un código de 6 dígitos en tu bandeja de entrada para verificar tu identidad de forma segura." wrapText="true" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <HBox alignment="CENTER" spacing="25.0">
                     <children>
                        <Hyperlink styleClass="footer-link" text="Política de Privacidad" />
                        <Hyperlink styleClass="footer-link" text="Términos de Servicio" />
                     </children>
                  </HBox>
                  <Label style="-fx-text-fill: #707882; -fx-font-size: 11px;" text="© 2026 Trello PDS Workspace Architecture" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>
