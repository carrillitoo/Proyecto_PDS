<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@Styles.css" styleClass="board-bg" xmlns="http://javafx.scene.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.BoardViewController">
   <children>
      
      <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="board-top-bar">
         <children>
            <Text style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Lanzamiento Q4" />
            <Button style="-fx-background-color: transparent;" text="★" />
            <Separator orientation="VERTICAL" prefHeight="20.0" />
            <HBox alignment="CENTER" spacing="-8.0">
               <children>
                  <Circle fill="#0079bf" radius="14.0" stroke="WHITE" strokeWidth="2.0" />
                  <Circle fill="#5aac44" radius="14.0" stroke="WHITE" strokeWidth="2.0" />
                  <Circle fill="#e0e3e6" radius="14.0" stroke="WHITE" strokeWidth="2.0" />
                  <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 0 10;" text="+4" />
               </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="nav-link" text="Filtrar" />
            <Button styleClass="nav-link" text="Compartir" />
         </children>
      </HBox>

      <ScrollPane fitToHeight="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
         <content>
            <HBox spacing="20.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  
                  <VBox spacing="10.0" styleClass="list-column">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="list-header-text" text="To Do" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label text="..." />
                           </children>
                        </HBox>
                        
                        <VBox spacing="8.0" fx:id="todoContainer">
                           <children>
                              <VBox spacing="8.0" styleClass="task-card">
                                 <children>
                                    <Region styleClass="label-high" />
                                    <Text wrappingWidth="240.0" text="Finalizar assets de diseño para campaña social" />
                                    <HBox alignment="CENTER_RIGHT">
                                       <children>
                                          <Circle fill="#ddd" radius="10.0" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #707882;" text="+ Añadir tarjeta" />
                     </children>
                  </VBox>

                  <VBox spacing="10.0" styleClass="list-column">
                     <children>
                        <Label styleClass="list-header-text" text="In Progress" />
                        <VBox spacing="8.0">
                           <children>
                              <VBox spacing="8.0" styleClass="task-card">
                                 <children>
                                    <Region styleClass="label-feature" />
                                    <Text wrappingWidth="240.0" text="Integración de API de pagos (Stripe)" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <Button styleClass="add-list-button" text="+ Añadir otra lista" />

               </children>
            </HBox>
         </content>
      </ScrollPane>
   </children>
</VBox>