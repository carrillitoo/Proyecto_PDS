<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #f8f9fc;" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.VerifyController">
   <children>
      <VBox alignment="CENTER" maxWidth="450.0" spacing="30.0">
         <children>
            
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text styleClass="brand-title" text="Tablerellos" />
                  <Rectangle height="4.0" styleClass="brand-underline" width="60.0" />
               </children>
            </VBox>

            <VBox spacing="25.0" styleClass="login-card">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <StackPane>
                           <children>
                              <Circle radius="30.0" styleClass="icon-circle-bg" />
                              <Text style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-fill: #005f98;" text="S" />
                           </children>
                        </StackPane>
                        <Text style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-font-family: 'Manrope';" text="Verificar Identidad" />
                        <Text style="-fx-fill: #707882; -fx-font-size: 13px; -fx-text-alignment: center;" text="Hemos enviado un codigo de 6 digitos a tu correo electronico asociado." wrappingWidth="300.0" />
                     </children>
                  </VBox>

                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <TextField fx:id="digit1" styleClass="code-digit-box" />
                        <TextField fx:id="digit2" styleClass="code-digit-box" />
                        <TextField fx:id="digit3" styleClass="code-digit-box" />
                        <TextField fx:id="digit4" styleClass="code-digit-box" />
                        <TextField fx:id="digit5" styleClass="code-digit-box" />
                        <TextField fx:id="digit6" styleClass="code-digit-box" />
                     </children>
                  </HBox>

                  <Button onAction="#handleVerify" maxWidth="Infinity" prefHeight="50.0" styleClass="btn-success-green" text="Confirmar Codigo" />
                  
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Text style="-fx-fill: #707882; -fx-font-size: 12px;" text="¿No has recibido el mensaje?" />
                        <Hyperlink onAction="#handleResendCode" style="-fx-text-fill: #156a03; -fx-font-weight: bold;" styleClass="footer-link" text="Reenviar codigo de seguridad" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text style="-fx-fill: #c0c7d2; -fx-font-size: 11px;" />
                  <Hyperlink onAction="#handleBackToLogin" styleClass="footer-link" text="Volver al inicio de sesion" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>
