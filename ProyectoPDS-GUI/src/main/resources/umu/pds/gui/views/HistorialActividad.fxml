<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.ActivityController">
   <content>
      <VBox spacing="30.0" style="-fx-padding: 40;">
         <children>
            <HBox alignment="BOTTOM_LEFT">
               <children>
                  <VBox spacing="5">
                     <children>
                        <Label style="-fx-text-fill: #0079bf; -fx-font-weight: bold; -fx-font-size: 12px;" text="LOGS DEL SISTEMA" />
                        <Text style="-fx-font-size: 32px; -fx-font-weight: 800;" text="Historial de Actividad" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #f2f4f7; -fx-padding: 10; -fx-background-radius: 12;">
                     <children>
                        <ComboBox prefWidth="150.0" promptText="Todos los usuarios" styleClass="filter-select" />
                        <Button styleClass="primary-button" text="Exportar" />
                     </children>
                  </HBox>
               </children>
            </HBox>

            <StackPane alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
               <children>
                  <Region maxWidth="2.0" styleClass="timeline-line">
                     <StackPane.margin>
                        <Insets left="24.0" />
                     </StackPane.margin>
                  </Region>

                  <VBox spacing="25.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="log-entry-container">
                           <children>
                              <Circle fill="WHITE" radius="24.0" stroke="#c0c7d2" />
                              <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                 <children>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label styleClass="log-user-name" text="John Doe" />
                                          <Label styleClass="log-action-text" text="movio" />
                                          <Label styleClass="log-target-text" text="Update Brand Assets" />
                                          <Label styleClass="log-action-text" text="de To Do a Doing" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label styleClass="log-timestamp" text="hace 2 min" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="log-entry-container">
                           <children>
                              <Circle fill="#cfe5ff" radius="24.0" stroke="#0079bf" />
                              <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                 <children>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label styleClass="log-user-name" text="Sarah Connor" />
                                          <Label styleClass="log-action-text" text="completo el item" />
                                          <Label style="-fx-font-style: italic;" text="Verify color contrast" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label styleClass="log-timestamp" text="hace 14 min" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="log-entry-container">
                           <children>
                              <Circle fill="#0079bf" radius="24.0" />
                              <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                 <children>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label styleClass="log-user-name" text="System Admin" />
                                          <Label styleClass="log-action-text" text="elimino a Mike Ross del espacio" />
                                          <Label styleClass="log-target-text" text="Design Systems" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label styleClass="log-timestamp" text="hace 3 horas" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                     </children>
                  </VBox>
               </children>
            </StackPane>
         </children>
      </VBox>
   </content>
</ScrollPane>
