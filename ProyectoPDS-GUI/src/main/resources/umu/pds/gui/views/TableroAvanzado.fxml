<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.AdvancedBoardController">
   
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-nav">
         <children>
            <Text style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-fill: #0079bf;" text="Trello PDS" />
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="primary-button" text="Crear" />
            <Circle fill="#e0e3e6" radius="16.0" stroke="#c0c7d2" />
         </children>
      </HBox>
   </top>

   <left>
      <VBox prefWidth="240.0" spacing="15" styleClass="sidebar">
         <children>
            <VBox spacing="5">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Engineering Board" />
                  <Label style="-fx-font-size: 11px; -fx-text-fill: #707882;" text="Product Team" />
               </children>
               <padding><Insets bottom="20" /></padding>
            </VBox>
            
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link, nav-link-active" text="Tablero" />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Tabla" />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Calendario" />
            
            <Region VBox.vgrow="ALWAYS" />
            <Separator />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Configuracion" />
         </children>
      </VBox>
   </left>

   <center>
      <VBox>
         <children>
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20 30;" stylesheets="@Styles.css">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Text style="-fx-font-size: 26px; -fx-font-weight: 800;" text="Engineering Board" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button styleClass="invite-button" text="Invitar" />
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Button styleClass="filter-button" text="Filtrar por etiqueta" />
                        <Separator orientation="VERTICAL" prefHeight="20.0" />
                        
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <HBox styleClass="filter-chip">
                                 <children>
                                    <Label prefHeight="28.0" prefWidth="51.0" styleClass="filter-chip-text" text="FE DEV  " />
                                    <Button styleClass="filter-chip-close" text="x" />
                                 </children>
                              </HBox>
                              <HBox styleClass="filter-chip">
                                 <children>
                                    <Label prefHeight="28.0" prefWidth="70.0" styleClass="filter-chip-text" text="URGENTE" />
                                    <Button prefHeight="26.0" prefWidth="16.0" styleClass="filter-chip-close" text="x" />
                                 </children>
                              </HBox>
                              <Button style="-fx-background-color: transparent; -fx-text-fill: #0079bf; -fx-font-size: 12px; -fx-font-weight: bold;" text="Limpiar todo" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <ScrollPane fitToHeight="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <HBox spacing="20.0" style="-fx-padding: 30;">
                     <children>
                        <VBox prefWidth="280.0" spacing="10.0" styleClass="list-column">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label styleClass="list-header-text" text="To Do" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button style="-fx-background-color: transparent;" text="..." />
                                 </children>
                              </HBox>
                              <VBox spacing="10.0">
                                 <children>
                                    <VBox spacing="10.0" styleClass="task-card">
                                       <children>
                                          <HBox spacing="5.0">
                                             <children>
                                                <Region prefWidth="40.0" styleClass="priority-indicator, priority-fe-dev" />
                                             </children>
                                          </HBox>
                                          <Text text="Optimizar renderizado del dashboard para navegadores antiguos" wrappingWidth="240.0" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>
                              <Button maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-text-fill: #707882;" text="+ Anadir tarjeta" />
                           </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="50.0" prefWidth="280.0" styleClass="new-board-placeholder">
                           <children>
                              <Label text="+ Anadir otra lista" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
