<VBox prefWidth="500.0" styleClass="create-board-modal" stylesheets="@Styles.css" xmlns="http://javafx.scene.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.CreateBoardController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0">
         <padding><Insets left="30.0" right="20.0" /></padding>
         <children>
            <Text style="-fx-font-size: 20px; -fx-font-weight: 800;" text="Crear tablero" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="X" style="-fx-background-color: transparent; -fx-font-weight: bold;" />
         </children>
      </HBox>
      <VBox spacing="25.0" style="-fx-padding: 0 30 40 30;">
         <children>
            <TextField fx:id="boardNameField" prefHeight="45.0" promptText="Nombre del tablero" styleClass="text-field" />
            <VBox spacing="10.0">
               <children>
                  <Label styleClass="input-label" text="PLANTILLA" />
                  <HBox spacing="10.0">
                     <children>
                        <Button styleClass="template-card" text="Vacio" prefWidth="120" />
                        <Button styleClass="template-card, template-card-active" text="Kanban" prefWidth="120" />
                        <Button styleClass="template-card" text="Lista" prefWidth="120" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Button fx:id="createButton" maxWidth="Infinity" onAction="#handleCreate" prefHeight="50.0" styleClass="primary-button" text="Crear" />
         </children>
      </VBox>
   </children>
</VBox>