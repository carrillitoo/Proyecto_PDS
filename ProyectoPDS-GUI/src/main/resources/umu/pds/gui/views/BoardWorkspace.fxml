<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.BoardWorkspaceController">
   
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" spacing="10">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12">
               <padding><Insets bottom="15" top="10" /></padding>
               <children>
                  <Rectangle fill="#005f98" height="32.0" width="32.0" arcHeight="8" arcWidth="8" />
                  <VBox>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Lanzamiento Q4" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #707882;" text="Espacio de Trabajo" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Separator />
            <VBox spacing="5" VBox.vgrow="ALWAYS">
               <children>
                  <Button maxWidth="Infinity" styleClass="nav-link" text="Kanban" onAction="#loadKanban" />
                  <Button maxWidth="Infinity" styleClass="nav-link" text="Miembros y Permisos" onAction="#loadMembers" />
                  <Button maxWidth="Infinity" styleClass="nav-link" text="Reglas (YAML)" onAction="#loadRules" />
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <StackPane fx:id="boardContentArea" style="-fx-background-color: #f8f9fc;" />
   </center>
</BorderPane>