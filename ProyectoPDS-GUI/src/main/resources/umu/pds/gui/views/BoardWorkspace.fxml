<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.BoardWorkspaceController">

   <!-- Header -->
   <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #e8f0fe; -fx-padding: 12 25;">
      <children>
         <Label fx:id="boardTitleLabel" style="-fx-font-size: 20px; -fx-font-weight: 800;" text="Tablero: (Cargando...)" />
         <Label fx:id="estadoBadge" />
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#loadKanban" styleClass="nav-link" text="Kanban" />
         <Button onAction="#loadMembers" styleClass="nav-link" text="Miembros" />
         <Button onAction="#loadTags" styleClass="nav-link" text="Etiquetas" />
         <Button fx:id="btnReglas" onAction="#loadRules" styleClass="nav-link" text="Compactación" />
         <Button fx:id="btnCongelar" onAction="#handleToggleFreeze" styleClass="nav-link" text="Congelar" />
      </children>
   </HBox>

   <!-- Content Area -->
   <StackPane fx:id="boardContentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: #f8f9fc;" />
</VBox>