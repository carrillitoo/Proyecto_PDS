<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<VBox prefWidth="480.0" spacing="0.0" styleClass="create-list-modal" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.CreateListController">
   <children>
      
      <HBox alignment="CENTER_LEFT" prefHeight="65.0" style="-fx-border-color: transparent transparent #eceef1 transparent; -fx-border-width: 1;">
         <padding>
            <Insets left="25.0" right="20.0" />
         </padding>
         <children>
            <Text style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-font-family: 'Manrope';" text="Crear Nueva Lista" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleClose" styleClass="btn-close-modal" text="X" />
         </children>
      </HBox>

      <VBox spacing="25.0" style="-fx-padding: 30 25 30 25;">
         <children>
            
            <VBox spacing="8.0">
               <children>
                  <Label styleClass="input-label" text="NOMBRE DE LA LISTA" />
                  <TextField fx:id="listNameField" prefHeight="45.0" promptText="Ej. Revision de Codigo (PDS)" styleClass="text-field" />
               </children>
            </VBox>

            <Separator style="-fx-opacity: 0.5;" />

            <VBox spacing="15.0" styleClass="rule-config-box">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Rectangle arcHeight="5" arcWidth="5" fill="#0079bf" height="18.0" width="4.0" />
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #191c1e;" text="Configuracion de Capacidad (N)" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" spacing="20.0">
                     <children>
                        <Slider fx:id="capacitySlider" blockIncrement="1.0" majorTickUnit="5.0" max="20.0" min="1.0" minorTickCount="4" snapToTicks="true" value="5.0" HBox.hgrow="ALWAYS" />
                        <Label fx:id="sliderValueLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0079bf;" text="5" />
                        <javafx.scene.control.CheckBox fx:id="unlimitedCheckbox" selected="true" text="Sin límite" style="-fx-font-size: 12px; -fx-text-fill: #404751;" />
                     </children>
                  </HBox>
                  <Label styleClass="label-help-text" text="Define el numero maximo de tarjetas permitidas. " />
               </children>
            </VBox>

            <VBox spacing="15.0" styleClass="rule-config-box">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Rectangle arcHeight="5" arcWidth="5" fill="#156a03" height="18.0" width="4.0" />
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #191c1e;" text="Restriccion de Origen" />
                     </children>
                  </HBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-font-style: normal; -fx-font-weight: bold; -fx-text-fill: #404751;" styleClass="label-help-text" text="SOLO PERMITIR ENTRADA DESDE:" />
                        <ComboBox fx:id="sourceRestrictionCombo" maxWidth="Infinity" prefHeight="40.0" promptText="Cualquier lista (Sin restriccion)" styleClass="filter-select" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 15 0 0 0;">
               <children>
                  <Button onAction="#handleClose" styleClass="btn-discard" text="Cancelar" />
                  <Button onAction="#handleCreateList" styleClass="primary-button" text="Crear Lista" />
               </children>
            </HBox>

         </children>
      </VBox>
   </children>
</VBox>
