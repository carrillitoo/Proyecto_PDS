<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="760.0" prefWidth="1200.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.MainLayoutController">
   
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-nav">
         <children>
            <Text style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-fill: #0079bf; -fx-cursor: hand;" text="Trello PDS" onMouseClicked="#goDashboard" />
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="create-button" text="Crear Tablero" onAction="#handleOpenCreateMenu" />
            <Circle fill="#e0e3e6" radius="16.0" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: #ba1a1a; -fx-font-weight: bold;" text="Salir" onAction="#logout" />
         </children>
      </HBox>
   </top>

   <center>
      <StackPane fx:id="contentArea" style="-fx-background-color: #f8f9fc;" />
   </center>
</BorderPane>