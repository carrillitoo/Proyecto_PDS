<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="760.0" prefWidth="1200.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.MainLayoutController">
   
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-nav">
         <children>
            <Text style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-fill: #0079bf; -fx-cursor: hand;" text="Trello PDS" onMouseClicked="#goDashboard" />
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="create-button" text="Crear Tablero" onAction="#handleOpenCreateMenu" />
            <Circle fill="#e0e3e6" radius="16.0" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: #ba1a1a; -fx-font-weight: bold;" text="Salir" onAction="#logout" />
         </children>
      </HBox>
   </top>

   <left>
      <VBox prefWidth="220.0" spacing="8" styleClass="sidebar">
         <padding>
            <Insets top="20" bottom="20" left="15" right="15" />
         </padding>
         <children>
            <VBox spacing="5">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="PDS Architect" />
                  <Label style="-fx-font-size: 10px; -fx-text-fill: #707882; -fx-font-weight: bold;" text="WORKSPACE" />
               </children>
               <padding><Insets bottom="15" /></padding>
            </VBox>
            <Separator />
            <Button maxWidth="Infinity" styleClass="nav-link" text="Dashboard" onAction="#goDashboard" />
            <Button maxWidth="Infinity" styleClass="nav-link" text="Tableros" onAction="#goBoard" />
            <Button maxWidth="Infinity" styleClass="nav-link" text="Permisos" onAction="#goPermissions" />
            <Button maxWidth="Infinity" styleClass="nav-link" text="Configuración" onAction="#goCompaction" />
            <Button maxWidth="Infinity" styleClass="nav-link" text="Plantillas YAML" onAction="#goTemplates" />
            <Button maxWidth="Infinity" styleClass="nav-link" text="Historial" onAction="#goHistory" />
            <Region VBox.vgrow="ALWAYS" />
            <Separator />
            <Button maxWidth="Infinity" style="-fx-text-fill: #ba1a1a;" styleClass="nav-link" text="Cerrar Sesión" onAction="#logout" />
         </children>
      </VBox>
   </left>

   <center>
      <StackPane fx:id="contentArea" style="-fx-background-color: #f8f9fc;" />
   </center>
</BorderPane>