<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.4);" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.InvitarMiembroController">

   <VBox maxWidth="500.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);">
      <children>
         
         <!-- Header -->
         <HBox alignment="CENTER_LEFT">
            <children>
               <Text style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-fill: #172b4d;" text="Invitar al Tablero" />
               <Region HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #6b778c; -fx-font-weight: bold; -fx-cursor: hand;" text="X" />
            </children>
         </HBox>
         
         <Label style="-fx-text-fill: #5e6c84; -fx-font-size: 13px;" text="Busca a un usuario por correo y otórgale permisos. Se generará un enlace de invitación." wrapText="true" />

         <!-- Input -->
         <VBox spacing="15.0">
            <children>
               <VBox spacing="5.0">
                  <children>
                     <Label styleClass="input-label" text="CORREO ELECTRÓNICO (AUTOCOMPLETADO)" />
                     <ComboBox fx:id="emailCombo" editable="true" prefWidth="1000.0" promptText="Empieza a escribir..." />
                  </children>
               </VBox>
               
               <VBox spacing="5.0">
                  <children>
                     <Label styleClass="input-label" text="PERMISOS" />
                     <ComboBox fx:id="rolCombo" prefWidth="1000.0" />
                  </children>
               </VBox>
            </children>
         </VBox>

         <!-- Actions -->
         <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
               <Button mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: #f4f5f7; -fx-text-fill: #172b4d; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16;" text="Cancelar" />
               <Button mnemonicParsing="false" onAction="#handleGenerarLink" styleClass="primary-button" text="Otorgar Permisos" />
            </children>
         </HBox>

         <!-- Link generado -->
         <VBox fx:id="linkContainer" managed="false" spacing="8.0" visible="false">
            <children>
               <Label styleClass="input-label" text="ENLACE DE INVITACIÓN" />
               <HBox spacing="10.0">
                  <children>
                     <TextField fx:id="linkGeneradoField" editable="false" styleClass="text-field" HBox.hgrow="ALWAYS" />
                     <Button mnemonicParsing="false" onAction="#handleCopiarLink" style="-fx-background-color: #0079bf; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16;" text="Copiar" />
                  </children>
               </HBox>
            </children>
            <VBox.margin>
               <Insets top="15.0" />
            </VBox.margin>
         </VBox>

      </children>
   </VBox>

</VBox>
