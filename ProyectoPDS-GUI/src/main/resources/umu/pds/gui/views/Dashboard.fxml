<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.DashboardController">
   <content>
      <VBox spacing="40.0" alignment="TOP_CENTER">
         <padding>
            <Insets bottom="50.0" left="80.0" right="80.0" top="40.0" />
         </padding>
         <children>
            
            <VBox spacing="20.0" maxWidth="900">
               <children>
                  <Text style="-fx-font-size: 28px; -fx-font-weight: 800;" text="Mis Tableros" />
                  <FlowPane fx:id="boardsContainer" hgap="20.0" vgap="20.0" />
               </children>
            </VBox>

            <VBox spacing="15.0" maxWidth="900">
               <children>
                  <Text style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Actividad Reciente" />
                  <VBox fx:id="activityContainer" spacing="10" styleClass="activity-card" />
               </children>
            </VBox>

         </children>
      </VBox>
   </content>
</ScrollPane>