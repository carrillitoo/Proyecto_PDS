<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.DashboardController">
   
   <left>
      <VBox prefWidth="240.0" spacing="10" styleClass="sidebar">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12">
               <padding>
                  <Insets bottom="20" />
               </padding>
               <children>
                  <Label styleClass="workspace-badge" text="M" />
                  <VBox>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Main Workspace" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link, nav-link-active" text="Tableros" />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Destacados" />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Vistas" />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Miembros" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Separator />
            <Button maxWidth="1.7976931348623157E308" styleClass="nav-link" text="Configuración" />
         </children>
      </VBox>
   </left>

   <center>
      <VBox>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-nav">
               <children>
                  <Text style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-fill: #0079bf;" text="Trello PDS" />
                  <HBox alignment="CENTER_LEFT" spacing="15">
                     <children>
                        <Hyperlink style="-fx-text-fill: #0079bf; -fx-font-weight: bold;" text="Workspaces" />
                        <Hyperlink style="-fx-text-fill: #404751;" text="Recientes" />
                        <Hyperlink style="-fx-text-fill: #404751;" text="Plantillas" />
                     </children>
                  </HBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button styleClass="create-button" text="Crear" />
                  <Label fx:id="userLabel" text="usuario@pds.com" />
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="30.0">
                     <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                     </padding>
                     <children>
                        <HBox alignment="BOTTOM_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Text style="-fx-font-size: 32px; -fx-font-weight: 800;" text="Mis Tableros" />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <Button fx:id="createBoardButton" onAction="#handleNewBoard" styleClass="primary-button" text="+ Crear nuevo tablero" />
                           </children>
                        </HBox>

                        <FlowPane fx:id="boardsContainer" hgap="20.0" vgap="20.0">
                           <children>
                              <VBox style="-fx-background-color: #0079bf;" styleClass="board-card">
                                 <children>
                                    <Label styleClass="board-card-title" text="Lanzamiento Q4" />
                                 </children>
                              </VBox>
                              <VBox style="-fx-background-color: #5aac44;" styleClass="board-card">
                                 <children>
                                    <Label styleClass="board-card-title" text="Rediseño UI" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER" onMouseClicked="#handleNewBoard" prefHeight="120" prefWidth="200" styleClass="new-board-placeholder">
                                 <children>
                                    <Label style="-fx-font-size: 30px; -fx-text-fill: #707882;" text="+" />
                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #707882; -fx-font-weight: bold;" text="Nuevo Tablero" />
                                 </children>
                              </VBox>
                           </children>
                        </FlowPane>

                        <VBox spacing="15.0">
                           <children>
                              <Text style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Actividad Reciente" />
                              <VBox spacing="10" styleClass="activity-card">
                                 <children>
                                    <Label style="-fx-font-weight: bold;" text="Actualizaste la tarjeta 'Moodboard Visual'" />
                                    <Label style="-fx-text-fill: #707882; -fx-font-size: 11px;" text="En Rediseño UI • Hace 2 horas" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
