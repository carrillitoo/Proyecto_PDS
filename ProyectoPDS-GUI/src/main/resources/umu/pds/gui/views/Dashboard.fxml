<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gui.controllers.DashboardController">
   <content>
      <VBox spacing="40.0" alignment="TOP_CENTER">
         <padding>
            <Insets bottom="50.0" left="80.0" right="80.0" top="40.0" />
         </padding>
         <children>
            
            <VBox spacing="20.0" maxWidth="900">
               <children>
                  <Text style="-fx-font-size: 28px; -fx-font-weight: 800;" text="Mis Tableros" />
                  <FlowPane fx:id="boardsContainer" hgap="20.0" vgap="20.0">
                     <children>
                        <VBox style="-fx-background-color: #0079bf;" styleClass="board-card" onMouseClicked="#abrirTableroWorkspace">
                           <children>
                              <Label styleClass="board-card-title" text="Lanzamiento Q4" />
                           </children>
                        </VBox>
                        <VBox style="-fx-background-color: #5aac44;" styleClass="board-card" onMouseClicked="#abrirTableroWorkspace">
                           <children>
                              <Label styleClass="board-card-title" text="Rediseño UI" />
                           </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="200" styleClass="new-board-placeholder" onMouseClicked="#handleNewBoard">
                           <children>
                              <Label style="-fx-font-size: 30px; -fx-text-fill: #707882;" text="+" />
                              <Label style="-fx-font-size: 12px; -fx-text-fill: #707882; -fx-font-weight: bold;" text="Nuevo Tablero" />
                           </children>
                        </VBox>
                     </children>
                  </FlowPane>
               </children>
            </VBox>

            <VBox spacing="15.0" maxWidth="900">
               <children>
                  <Text style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Actividad Reciente" />
                  <VBox spacing="10" styleClass="activity-card">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Actualizaste la tarjeta 'Moodboard Visual'" />
                        <Label style="-fx-text-fill: #707882; -fx-font-size: 11px;" text="En Rediseño UI • Hace 2 horas" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <Separator maxWidth="900" style="-fx-padding: 20 0;" />

            <VBox alignment="CENTER" spacing="15.0" maxWidth="900" style="-fx-background-color: #e6e8eb; -fx-padding: 30; -fx-background-radius: 12;">
               <children>
                  <Text style="-fx-font-size: 22px; -fx-font-weight: 800;" text="Automatización Avanzada" />
                  <Text style="-fx-fill: #404751; -fx-text-alignment: center;" text="Crea tableros complejos cargando archivos YAML preconfigurados o gestiona tus plantillas." />
                  <Button styleClass="primary-button" text="Ir a Plantillas YAML" onAction="#abrirPlantillasYAML" />
               </children>
            </VBox>

         </children>
      </VBox>
   </content>
</ScrollPane>