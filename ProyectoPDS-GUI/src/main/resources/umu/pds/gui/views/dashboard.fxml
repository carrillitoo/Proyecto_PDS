<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.scene.com/javafx/8.0.171" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="umu.pds.gui.controllers.DashboardController"
            style="-fx-background-color: #ebedf0;">
    
    <top>
        <HBox spacing="20.0" alignment="CENTER_LEFT" 
              style="-fx-background-color: #026aa7; -fx-padding: 10 25 10 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);">
            <children>
                <Text text="Trello PDS" style="-fx-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', Helvetica;" />
                <Region HBox.hgrow="ALWAYS" />
                
                <HBox alignment="CENTER" spacing="10">
                    <Label fx:id="userLabel" text="usuario@pds.com" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Button text="Cerrar Sesión" onAction="#handleLogout" 
                            style="-fx-background-color: #eb5a46; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" />
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="25.0">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Text text="Tus Tableros" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #172b4d;" />
                    <Button text="+ Crear nuevo tablero" onAction="#handleNewBoard"
                            style="-fx-background-color: #5aac44; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 3;" />
                </HBox>
                
                <Separator />

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" 
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <FlowPane fx:id="boardsContainer" hgap="20.0" vgap="20.0">
                            <VBox alignment="CENTER" prefHeight="100" prefWidth="200" 
                                  style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;">
                                <Label text="¡Empieza creando uno!" style="-fx-text-fill: #5e6c84; -fx-font-style: italic;" />
                            </VBox>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>