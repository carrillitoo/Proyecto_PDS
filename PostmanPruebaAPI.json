{
  "info": {
    "name": "Proyecto PDS API",
    "description": "Colección para probar los endpoints de Tableros y Tarjetas del Proyecto PDS. Puedes importar este archivo en Postman o Insomnia.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tableros",
      "item": [
        {
          "name": "1. Crear Tablero",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Tablero de Pruebas\",\n  \"emailCreador\": \"usuario@ejemplo.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/tableros",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "tableros"]
            }
          }
        },
        {
          "name": "2. Obtener Tablero",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/tableros/{{TABLERO_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "tableros", "{{TABLERO_ID}}"]
            }
          }
        },
        {
          "name": "3. Congelar Tablero",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/tableros/{{TABLERO_ID}}/congelar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "tableros", "{{TABLERO_ID}}", "congelar"]
            }
          }
        },
        {
          "name": "4. Descongelar Tablero",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/tableros/{{TABLERO_ID}}/descongelar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "tableros", "{{TABLERO_ID}}", "descongelar"]
            }
          }
        },
        {
          "name": "5. Compactar Tablero",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diasInactividad\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/tableros/{{TABLERO_ID}}/compactar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "tableros", "{{TABLERO_ID}}", "compactar"]
            }
          }
        }
      ]
    },
    {
